# ── LLM Providers ──────────────────────────────────────────────────────────
# Provider waterfall: primary → secondary → tertiary → static text
LLM_PROVIDER_PRIMARY=groq
LLM_PROVIDER_SECONDARY=gemini
LLM_PROVIDER_TERTIARY=openrouter

# Groq (primary) — https://console.groq.com (free tier: 14,400 req/day)
# Sign up → API Keys → create key
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Gemini (secondary fallback) — https://aistudio.google.com (free, no card needed)
# Sign up → Get API Key → copy key
GEMINI_API_KEY=AIza_your_key_here
GEMINI_MODEL=gemini-2.0-flash

# OpenRouter (last-resort fallback) — https://openrouter.ai
OPENROUTER_API_KEY=sk-or-your_key_here
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Database ───────────────────────────────────────────────────────────────
# Neon PostgreSQL (same as V2 main app — READ-ONLY connection)
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?ssl=require

# ── Redis Cache ────────────────────────────────────────────────────────────
# Upstash Redis (free tier works for MVP)
REDIS_URL=redis://localhost:6379
# For Upstash: rediss://default:password@host:6380

# ── App Config ─────────────────────────────────────────────────────────────
APP_ENV=development        # development | production
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Feature Flags ──────────────────────────────────────────────────────────
# Set to "true" to use mock data instead of real DB (for chatbot-only dev)
USE_MOCK_DATA=true

# ── Rate Limiting ──────────────────────────────────────────────────────────
LLM_RATE_LIMIT_PER_MINUTE=20
LLM_TIMEOUT_SECONDS=10

# ── Session Config ─────────────────────────────────────────────────────────
SESSION_TTL_SECONDS=1800           # 30 minutes
CONTEXT_CACHE_TTL_SECONDS=300      # 5 minutes
IN_SESSION_MESSAGE_LIMIT=10        # messages kept in Redis per session
