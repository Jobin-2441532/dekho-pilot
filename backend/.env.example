# Dekho Backend — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git

GEMINI_API_KEY=your_gemini_api_key_here

# Database — SQLite for local dev, Postgres for Docker/production
DATABASE_URL=sqlite:///./dekho.db
# DATABASE_URL=postgresql://dekho:dekho_password@localhost:5432/dekho_db

# FAISS vector store path
FAISS_INDEX_PATH=./data/vector_store

# Knowledge base and data directories
DATA_DIR=../data
KNOWLEDGE_BASE_DIR=../knowledge-base

# Frontend origin for CORS
FRONTEND_ORIGIN=http://localhost:5173

# MinIO (S3-compatible storage) — optional, files saved locally if unavailable
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=dekho_minio
MINIO_SECRET_KEY=dekho_minio_password
MINIO_BUCKET=dekho-uploads
MINIO_SECURE=false

# Redis — optional, used by background jobs
REDIS_URL=redis://localhost:6379/0

# JWT — CHANGE THIS IN PRODUCTION
JWT_SECRET_KEY=change-this-in-production-to-a-long-random-string

# ML Sidecar URL
ML_SERVICE_URL=http://localhost:8001
