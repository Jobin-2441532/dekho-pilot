# ─────────────────────────────────────────────────────
# Dekho — Root .gitignore
# ─────────────────────────────────────────────────────

# ── Python ────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.pdb
.Python

# Virtual environments
venv/
.venv/
env/

# ── Databases (local dev only) ────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Logs ─────────────────────────────────────────────
*.log
backend_log.txt
backend/backend_log.txt

# ── Environment files (contains API keys!) ───────────
# NOTE: .env.example is safe to commit; .env is NOT
.env
backend/.env
ml_service/.env

# ── Node / Frontend ───────────────────────────────────
node_modules/
frontend/node_modules/
ml_service/node_modules/
dist/
frontend/dist/
.vite/

# ── FAISS / ML model artefacts ────────────────────────
backend/data/faiss_index/
backend/data/vector_store/
backend/data/uploads/
ml_service/data/

# ── macOS / Windows ───────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDEs ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Docker ────────────────────────────────────────────
# Keep Dockerfiles but ignore local build artifacts
.docker/

# ── Misc project files (not needed in repo) ───────────
Statement1.csv
Coworker_Project_Details.md
backend_todo.md
